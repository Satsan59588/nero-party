# Server
PORT=3000

# Spotify API (Client Credentials — no user login needed)
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube Data API v3 (for video lookup & playback)
# Get from https://console.cloud.google.com — enable "YouTube Data API v3"
YOUTUBE_API_KEY=
